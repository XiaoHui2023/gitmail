SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=gitmail@example.com
SMTP_PASSWORD=your-password-or-app-token
SMTP_FROM=Git Monitor <gitmail@example.com>
SMTP_USE_TLS=true
# 启动时向 SMTP_USER 发送自检邮件；设为 false 可跳过
SMTP_STARTUP_CHECK=true

# OpenAI 兼容接口（可选；留空则跳过 AI 总结）
AI_API_URL=https://api.openai.com/v1
AI_API_KEY=sk-your-api-key
AI_MODEL=gpt-4o-mini
# 启动时调用一次最小对话验证连通性；设为 false 可跳过
AI_STARTUP_CHECK=true
